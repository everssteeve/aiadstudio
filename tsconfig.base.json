{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@aiad/shared": ["./packages/shared/src/index.ts"],
      "@aiad/db": ["./packages/db/src/index.ts"],
      "@aiad/adapters": ["./packages/adapters/src/index.ts"]
    }
  }
}
